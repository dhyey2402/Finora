# SmartERP Environment Configuration
# Copy this file to .env and fill in your values

# Application
APP_NAME=SmartERP
APP_VERSION=1.0.0
DEBUG=True
HOST=0.0.0.0
PORT=8000

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://neondb_owner:your_password@your_host/neondb?sslmode=require

# JWT / Authentication
SECRET_KEY=generate-a-secret-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
